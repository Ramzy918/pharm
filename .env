# ==========================================
# CONFIGURATION ÉQUIPE - MODE DISTRIBUÉ
# ==========================================

# 1. IPs des machines
MY_IP=172.20.10.3
PARTNER_IP=172.20.10.10

# 2. MASTER_IP : L'IP de la machine qui héberge Consul et RabbitMQ
# Dans votre cas, c'est VOUS (172.20.10.3)
MASTER_IP=172.20.10.3

# 3. Adresses des services (pour que le Web-UI sache où taper)
# L'Auth est chez vous, le Catalog est chez votre partenaire
AUTH_IP=172.20.10.3
CATALOG_IP=172.20.10.7

# 4. Configuration Secrets
DJANGO_SECRET_KEY=dev-secret-auth-only
DJANGO_SECRET_KEY_CATALOG=dev-secret-catalog-only
DJANGO_SECRET_KEY_WEB=dev-secret-web-only
JWT_SIGNING_KEY=shared-jwt-secret-must-match-auth-and-catalog

# 5. Configuration RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# 6. Devises et Taux
CURRENCY_CODE=DZD
CURRENCY_SYMBOL=DA
EGP_TO_DZD_RATE=2.70

# 7. Configuration Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=marketpharm.algerie.shop@gmail.com
SMTP_PASS=whyhdgbvorfwimoo

